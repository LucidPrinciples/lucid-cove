# Lucid Cove — environment contract
# Generated from src/env.py (the single source of truth). Do not hand-edit;
# run:  python3 -m src.env > .env.example
#
# Secrets are blank placeholders — fill them in your private .env, never here.

# ── Runtime ─────────────────────────────────────────────────────
# single = one agent (Cove steward); multi = shared app (operators).
COVE_MODE=single
# Stable id for this Cove.
COVE_ID=
# Family/Cove display name. (was: '' vs 'name' — canonical '').
COVE_NAME=
# Primary agent id; code may override via get_primary_agent_id().
AGENT_ID=agent
# production | development.
ENVIRONMENT=production
# App listen port.
PORT=8200
# IANA tz for the Cove.
APP_TIMEZONE=America/New_York
# Published host ports (stamped by the provisioner; runtime surfaces read them
# so a second Cove on a box reports its REAL bumped ports).
NEXTCLOUD_PORT=8080
MATRIX_PORT=8008
# Overlay-provided Vault doc catalog (JSON). Empty = the built-in KB-only default.
VAULT_CATALOG_FILE=
# Host path of this Cove's folder (stamped by install.sh provisions; the mesh-step
# UI uses it to render a full-path join command). Empty = unknown.
COVE_HOST_DIR=
# Direct-TLS cert paths (legacy — Caddy terminates TLS; only for deployments
# that still mount certs into /ssl).
SSL_CERT_FILE=
SSL_KEY_FILE=
# Co-located host-Caddy dir for the non-shared/non-bundled snippet path
# (deploy.caddy_dir in the provision config also sets it).
LP_CADDY_DIR=
# Shared-Caddy conf.d dir the app writes per-Cove routing snippets into
# (set by the provisioner in the shared-Caddy layout).
COVE_SHARED_CONFD=
# The Cove's own docker dir (holds the bundled-Caddy Caddyfile the app persists).
COVE_DOCKER_DIR=
# Watcher infra-drift checks (#D33) — optional overrides. Colon-separated list of
# Caddy config artifacts to watch for drift; and the Caddy cert store dir to scan
# for near-expiry TLS certs. Both no-op if the paths aren't mounted in-container.
LP_WATCHER_CADDY_PATHS=
LP_WATCHER_CADDY_CERT_DIR=
# Process home dir.
HOME=/root
# Bound operator account (single-op Coves).
OPERATOR_ACCOUNT_ID=
# Cove owner email.
OWNER_EMAIL=
# Agent ids to skip in team dispatch.
SKIP_AGENTS=

# ── Paths ───────────────────────────────────────────────────────
# Writable app data dir.
DATA_DIR=/app/data
# Steward data dir. (was: '/app/data' vs '/data' — canonical '/app/data').
STUART_DATA_DIR=/app/data
# Mounted vault root. (was: '/vault' vs '/vault/LP-Vault' — canonical '/vault').
VAULT_DIR=/vault
# Framework KB dir.
FRAMEWORK_DIR=/cove-core/data/knowledge-base
# Generated avatar store.
LP_AVATAR_DIR=/app/data/avatars
# Live runbook JSON dir.
RUNBOOKS_DIR=/app/data/runbooks
# Seed runbook JSON dir.
RUNBOOKS_SEED_DIR=/cove-core/runbooks
# Video pipeline root.
VIDEO_BASE_PATH=/vault/AgentSkills/Content/video
# Moments-analysis model on the Groq pipeline key (override if Groq rotates ids).
LP_MOMENTS_GROQ_MODEL=llama-3.3-70b-versatile
# Moments-analysis model on the OpenAI pipeline key.
LP_MOMENTS_OPENAI_MODEL=gpt-4o-mini
# Nextcloud-synced Sites path (optional).
SITES_NC_PATH=
# LTP package cache dir.
TUNING_PACKAGES_DIR=/app/data/tuning-packages
# Runtime tuning-key reference json (optional).
LT_REFERENCE_PATH=
# LangGraph checkpoint db.
SQLITE_PATH=./data/checkpoints.db

# ── Database ────────────────────────────────────────────────────
# Primary Postgres DSN.
DATABASE_URL=
# Steward DB DSN (team agents point here).
STEWARD_DATABASE_URL=
# Mercer DB DSN.
MERCER_DATABASE_URL=

# ── Secrets ─────────────────────────────────────────────────────
# Service-to-service + admin endpoint secret.
SHARED_CONTAINER_SECRET=
# URL of the shared container.
SHARED_CONTAINER_URL=
# Operator's app-account token (registry self-join).
LP_OPERATOR_TOKEN=
# Affiliate handle that referred this install.
LP_REFERRED_BY=

# ── Registry ────────────────────────────────────────────────────
# Truthy ONLY on the hub/public app (the registrar). Empty on Coves.
LP_REGISTRY_MASTER=
# Hub registrar base URL (Coves point here).
LP_REGISTRY_URL=
# Fleet registry write secret.
LP_REGISTRY_SECRET=
# Public app base URL.
LP_PUBLIC_BASE=https://app.lucidcove.org
# Marketplace/commerce API base (Socrates).
MARKETPLACE_API_URL=
# Extra Cove/Haven names to reserve (anti-squat), comma-separated. Deployment-specific so no operator value is hardcoded in the core (e.g. a hub sets its own Haven name here).
LP_EXTRA_RESERVED_COVE_NAMES=

# ── Models ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# LP-provided OpenRouter key scoped to the GUIDED cove-creation tour ONLY (flow_chat). Does NOT power an operator's normal agent — that needs their own key or Ollama. Lets a keyless self-hoster try Guided on LP's dime.
LP_GUIDED_OPENROUTER_KEY=
# Override OpenRouter base (optional).
OPENROUTER_BASE_URL=
MOONSHOT_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
# Cloud ASR (Deepgram) for video transcription.
DEEPGRAM_API_KEY=
# Local Ollama. (was: host.docker.internal vs localhost — canonical host.docker.internal).
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Display label for the primary model.
PRIMARY_MODEL=unknown
# Display label for the fallback model.
FALLBACK_MODEL=unknown

# ── Nextcloud ───────────────────────────────────────────────────
# NC base URL. Canonical: http://nextcloud:80 (bundled NC service, internal port 80). Compose overrides per deploy.
NEXTCLOUD_URL=http://nextcloud:80
# Per-presence NC user.
NEXTCLOUD_USER=
# Per-presence NC app password.
NEXTCLOUD_PASSWORD=
# NC admin user. (was: '' vs 'admin' vs NEXTCLOUD_USER fallback — canonical 'admin').
NEXTCLOUD_ADMIN_USER=admin
# NC admin password.
NEXTCLOUD_ADMIN_PASSWORD=
# Public NC URL (for share links).
NEXTCLOUD_PUBLIC_URL=
# NC URL pipecat uses for WebDAV.
NC_PIPECAT_URL=

# ── Matrix ──────────────────────────────────────────────────────
# This Cove's homeserver URL.
MATRIX_HOMESERVER=
# Matrix server_name (handle domain).
MATRIX_SERVER_NAME=
# Public client URL.
MATRIX_PUBLIC_URL=
# Hub homeserver for cross-Cove resolution.
MATRIX_HUB_URL=
# Shared registration secret.
MATRIX_REG_SECRET=
# Operator's matrix localpart.
MATRIX_OPERATOR_USER=
# Operator's matrix password.
MATRIX_OPERATOR_PASSWORD=
# Steward matrix localpart.
MATRIX_STEWARD_LOCALPART=steward

# ── Voice ───────────────────────────────────────────────────────
# Pipecat voice service.
PIPECAT_URL=http://host.docker.internal:8300
# Shared secret gating pipecat's internal endpoints (CF-78 — minted by the provisioner
# on fresh installs; existing sharing Coves get a fix card until both are set).
PIPECAT_INTERNAL_SECRET=
# URL pipecat calls to verify a GPU grant token (CF-78, pairs with the secret above).
GPU_GRANT_VERIFY_URL=
# Internal voice URL.
VOICE_INTERNAL_URL=http://host.docker.internal:8300
# Public wss voice URL (derived if empty).
VOICE_PUBLIC_URL=

# ── Email ───────────────────────────────────────────────────────
BREVO_API_KEY=
# Verified sender.
BREVO_SENDER_EMAIL=signin@lucidprinciples.com
# Sender display name.
BREVO_SENDER_NAME=Lucid Principles
# Onboarding contact list id.
BREVO_LIST_ID=4
# Product name in email copy.
EMAIL_PRODUCT_NAME=Lucid Principles

# ── Commerce ────────────────────────────────────────────────────
# Marketplace platform fee.
LP_PLATFORM_FEE_RATE=0.10
# L1 affiliate share of net fee.
LP_AFFILIATE_L1_RATE=0.30
# L2 affiliate share of net fee.
LP_AFFILIATE_L2_RATE=0.10

# ── LTP ─────────────────────────────────────────────────────────
# If true, tuning side effects are skipped. (was: 'false' vs 'true' — canonical 'false').
LTP_DRY_RUN=false
# Provenance label for tunings.
LTP_SOURCE=unknown
# Subscribe to the public LTP Drop.
LTP_DROP_ENABLED=true
# LTP Drop base URL.
LTP_DROP_URL=https://drop.lucidprinciples.com
# Drop signature public key.
LTP_DROP_PUBKEY=
# git | http delivery of packages.
TUNING_DELIVERY=git
# Tuning family key.
TUNING_FAMILY=default
# HTTP package source (if delivery=http).
TUNING_HTTP_URL=
# Git package source (if delivery=git).
TUNING_REPO_URL=
# Default mirror source key.
ACTIVE_MIRROR=scripture-tpt
# Which calendar drives notifications.
NOTIFY_CALENDAR=personal

# ── KB ──────────────────────────────────────────────────────────
# Signed KB manifest.
LP_KB_MANIFEST_URL=https://drop.lucidprinciples.com/kb/manifest.json
# KB Drop verify-key (public). Baked default; consume KB.
LP_KB_PUBLIC_KEY=MCowBQYDK2VwAyEAMtpeQ7Gae3YUwzUVjh2fyToF/oGi2OBWUWipXia0BeM=

# ── Hosting ─────────────────────────────────────────────────────
# Base domain for provisioned Coves.
HOSTING_BASE_DOMAIN=lucidcove.org
# Where generated overlays land.
HOSTING_OUTPUT_DIR=/hosting/coves
# cove-core path on the host.
HOSTING_COVE_CORE_PATH=/docker/cove-core
# Caddy config dir (optional auto-deploy).
HOSTING_CADDY_DIR=
# Mesh IP for the provisioned Cove.
HOSTING_MESH_IP=
# Auto docker-compose after provision.
HOSTING_AUTO_DEPLOY=
# THIS box's mesh IP (written into the instance .env by connect-mesh.sh /
# install.sh preflight; the address claim points DNS here).
COVE_MESH_IP=

# ── Social ──────────────────────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# If true, X posts are logged not sent.
X_DRY_RUN=false
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# OAuth redirect URI.
YOUTUBE_REDIRECT_URI=

# ── Infra ───────────────────────────────────────────────────────
# Backup git repo dir.
BACKUP_REPO_DIR=/backup/agent
# Backup commit author name.
BACKUP_GIT_NAME=MC Backup
# Backup commit author email.
BACKUP_GIT_EMAIL=backup@mc.internal
# Optional self-hosted search.
SEARXNG_URL=http://localhost:8888

# ── Co-located Cove tuning coordination ─────────────────────────
# Shared lock dir mounted into EVERY co-located Cove so their morning
# tunings serialize (one GPU). Empty = per-container lock only.
LP_TUNE_LOCK_DIR=
# Lock considered stale after this many seconds (crashed holder never wedges the fleet).
LP_TUNE_LOCK_STALE_SECS=1800
